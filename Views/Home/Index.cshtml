@{
    ViewData["Title"] = "Welcome to EventEase";
}

<div class="text-center">
    <h1 class="display-4">Welcome to EventEase</h1>

    <p class="lead">
        EventEase is your all-in-one platform to discover and book top venues for weddings, conferences, parties, and more.
        We simplify the venue booking process with transparent pricing, real-time availability, and user reviews.
    </p>

    <img src="data:image/png;base64," alt="EventEase Logo" class="img-fluid my-4" style="max-height: 150px;">

    <h2 class="mt-5">Get Started</h2>
    <div class="d-flex justify-content-center flex-wrap">
        <a asp-controller="Venues" asp-action="Index" class="btn btn-primary m-2">Explore Venues</a>
        <a asp-controller="Bookings" asp-action="Index" class="btn btn-success m-2">Book Now</a>
        <a asp-controller="Home" asp-action="Contact" class="btn btn-info m-2">Contact Us</a>
    </div>

    <h3 class="mt-5">Why Choose EventEase?</h3>
    <div class="row mt-4">
        <div class="col-md-4">
            <img src="https://cdn-icons-png.flaticon.com/512/2423/2423800.png" alt="Easy Booking" class="img-fluid mb-2" style="max-height: 100px;">
            <p><strong>Easy Booking:</strong> Reserve your venue in just a few clicks.</p>
        </div>
        <div class="col-md-4">
            <img src="https://cdn-icons-png.flaticon.com/512/2936/2936885.png" alt="Verified Venues" class="img-fluid mb-2" style="max-height: 100px;">
            <p><strong>Verified Venues:</strong> Choose from a list of trusted and reviewed venues.</p>
        </div>
        <div class="col-md-4">
            <img src="https://cdn-icons-png.flaticon.com/512/888/888879.png" alt="Customer Support" class="img-fluid mb-2" style="max-height: 100px;">
            <p><strong>24/7 Support:</strong> Our team is here to help you anytime.</p>
        </div>
    </div>
</div>
