@model EventEase.Models.Event

@{
    ViewData["Title"] = "Event Details";
}

<div class="container mt-4">
    <div class="card">
        <div class="card-header bg-primary text-white">
            <h4>Event Details</h4>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-4">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" class="img-fluid rounded" alt="Event image">
                    }
                    else
                    {
                        <div class="text-center py-4 bg-light rounded">
                            <i class="fas fa-calendar-alt fa-5x text-muted"></i>
                            <p class="mt-2">No image available</p>
                        </div>
                    }
                </div>
                <div class="col-md-8">
                    <dl class="row">
                        <dt class="col-sm-3">ID:</dt>
                        <dd class="col-sm-9">@Model.Id</dd>

                        <dt class="col-sm-3">Name:</dt>
                        <dd class="col-sm-9">@Model.Name</dd>

                        <dt class="col-sm-3">Type:</dt>
                        <dd class="col-sm-9">
                            <span class="badge bg-primary">@Model.EventType</span>
                        </dd>

                        <dt class="col-sm-3">Date:</dt>
                        <dd class="col-sm-9">@Model.EventDate.ToString("f")</dd>

                        <dt class="col-sm-3">Description:</dt>
                        <dd class="col-sm-9">@Model.Description</dd>
                    </dl>
                </div>
            </div>
        </div>
        <div class="card-footer">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                <i class="fas fa-edit"></i> Edit
            </a>
            <a asp-action="Index" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Back to List
            </a>
        </div>
    </div>
</div>
