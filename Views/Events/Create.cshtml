@model EventEase.Models.Event

@{
    ViewData["Title"] = "Create Event";
}

<div class="container mt-4">
    <h2>Create New Event</h2>
    <form asp-action="Create" method="post" enctype="multipart/form-data">
        <div class="mb-3">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" class="form-control"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="EventDate" class="form-label"></label>
            <input asp-for="EventDate" class="form-control" type="datetime-local" />
            <span asp-validation-for="EventDate" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="EventTypeId" class="form-label">Event Type</label>
            <select asp-for="EventTypeId" class="form-select" asp-items="ViewBag.EventTypes">
                <option value="">Select Event Type</option>
            </select>
            <span asp-validation-for="EventTypeId" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Upload Event Image</label>
            <input type="file" name="imageFile" class="form-control" accept="image/*" />
        </div>

        <div class="d-flex justify-content-between">
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            <button type="submit" class="btn btn-primary">Create</button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}